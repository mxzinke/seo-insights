# Copy this file to config/gsc.env and fill in your credentials.
# NEVER commit the real gsc.env — it is listed in .gitignore.
#
# OAuth 2.0 credentials from Google Cloud Console
# (Web Application type, with offline access scope).
GSC_CLIENT_ID=your-client-id.apps.googleusercontent.com
GSC_CLIENT_SECRET=your-client-secret
GSC_REFRESH_TOKEN=your-refresh-token

# Google Search Console site URL.
# Two formats accepted:
#   sc-domain:example.com        (domain property — covers all protocols/subdomains)
#   https://www.example.com/     (URL-prefix property — must include trailing slash)
GSC_SITE_URL=sc-domain:example.com

# Optional — needed for Core Web Vitals analysis via PageSpeed Insights API.
# Leave blank or omit to skip CWV analysis gracefully.
PAGESPEED_API_KEY=

# ─── Google Ads API (optional) — enables search volume + keyword ideas ─────────
# Without these, keyword research still runs in free mode (GSC + autocomplete).
# All three keys below are required together for Ads integration.
#
# Developer token — from Google Ads → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=
#
# Your Google Ads customer ID (MCC or standard account; digits only, e.g. 1234567890)
GOOGLE_ADS_CUSTOMER_ID=
#
# Manager (MCC) login customer ID — only needed when using a manager account.
# Leave blank if GOOGLE_ADS_CUSTOMER_ID IS the account you query directly.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
#
# Note: the OAuth token above (GSC_REFRESH_TOKEN) must also have the adwords scope:
#   https://www.googleapis.com/auth/adwords
# If you created your refresh token for GSC only, re-run `auth.py consent` with
# both scopes and exchange a new code.
