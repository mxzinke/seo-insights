# Copy this file to config/gsc.env and fill in your credentials.
# NEVER commit the real gsc.env — it is listed in .gitignore.
#
# OAuth 2.0 credentials from Google Cloud Console
# (Web Application type, with offline access scope).
GSC_CLIENT_ID=your-client-id.apps.googleusercontent.com
GSC_CLIENT_SECRET=your-client-secret
GSC_REFRESH_TOKEN=your-refresh-token

# Google Search Console site URL.
# Two formats accepted:
#   sc-domain:example.com        (domain property — covers all protocols/subdomains)
#   https://www.example.com/     (URL-prefix property — must include trailing slash)
GSC_SITE_URL=sc-domain:example.com

# Optional — needed for Core Web Vitals analysis via PageSpeed Insights API.
# Leave blank or omit to skip CWV analysis gracefully.
PAGESPEED_API_KEY=
