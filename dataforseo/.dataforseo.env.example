# DataForSEO credentials — copy this to .dataforseo.env and fill in your values.
# NEVER commit .dataforseo.env to git (it is already in .gitignore).
#
# How to get credentials:
#   1. Register at https://app.dataforseo.com/register
#   2. Top up your account (minimum $50 required)
#   3. Your login is your registration email
#   4. Your API password is shown at https://app.dataforseo.com/api-access
#
# Alternatively, set these as environment variables:
#   export DATAFORSEO_LOGIN=your@email.com
#   export DATAFORSEO_PASSWORD=your_api_password

DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your_api_password
